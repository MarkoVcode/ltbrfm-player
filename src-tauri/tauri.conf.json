{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LTBR FM Receiver",
  "version": "0.1.2",
  "identifier": "fm.ltbr.player",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "LTBR·FM Receiver",
        "width": 720,
        "height": 548,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "shadow": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "shortDescription": "LTBR·FM Receiver",
    "longDescription": "A rock-solid cross-platform Icecast radio receiver with a 10-band graphic equaliser and an LED spectrum analyser.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libasound2"]
      }
    }
  }
}
